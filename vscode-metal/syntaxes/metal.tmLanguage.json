{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Metal",
  "scopeName": "source.metal",
  "fileTypes": ["metal", "msl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#qualifiers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.metal",
          "match": "//.*$"
        },
        {
          "name": "comment.block.metal",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "name": "meta.preprocessor.metal",
      "match": "^\\s*#\\s*(include|define|undef|if|ifdef|ifndef|else|elif|endif|pragma|error|warning)\\b.*$",
      "captures": {
        "0": { "name": "keyword.control.directive.metal" }
      }
    },
    "attributes": {
      "name": "meta.attribute.metal",
      "begin": "\\[\\[",
      "end": "\\]\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.attribute.metal" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.attribute.metal" } },
      "patterns": [
        {
          "name": "entity.other.attribute-name.metal",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.metal",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.metal", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.metal",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlLfFhH]*\\b"
        },
        {
          "name": "constant.numeric.float.metal",
          "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?[fFhH]?\\b"
        },
        {
          "name": "constant.numeric.integer.metal",
          "match": "\\b\\d+[uUlL]*\\b"
        }
      ]
    },
    "keywords": {
      "name": "keyword.control.metal",
      "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|discard_fragment|struct|class|enum|typedef|using|namespace|template|typename|const|constexpr|static|inline|volatile|sizeof)\\b"
    },
    "qualifiers": {
      "name": "storage.modifier.metal",
      "match": "\\b(kernel|vertex|fragment|device|constant|thread|threadgroup|ray_data|object_data|packed)\\b"
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.metal",
          "match": "\\b(void|bool|char|uchar|short|ushort|int|uint|long|ulong|float|half|bfloat|size_t|ssize_t|ptrdiff_t|intptr_t|uintptr_t|int8_t|int16_t|int32_t|int64_t|uint8_t|uint16_t|uint32_t|uint64_t)\\b"
        },
        {
          "name": "storage.type.vector.metal",
          "match": "\\b(bool|char|uchar|short|ushort|int|uint|long|ulong|half|float|bfloat)[234]\\b"
        },
        {
          "name": "storage.type.matrix.metal",
          "match": "\\b(float|half)[234]x[234]\\b"
        },
        {
          "name": "storage.type.texture.metal",
          "match": "\\b(texture1d|texture2d|texture3d|texturecube|texture1d_array|texture2d_array|texture2d_ms|texturecube_array|depth2d|depth2d_ms|depth2d_array|depthcube|depthcube_array|sampler|atomic_int|atomic_uint)\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.metal",
      "match": "(\\+\\+|--|&&|\\|\\||<<=|>>=|<<|>>|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|::|->|[+\\-*/%=<>!&|^~?:])"
    }
  }
}
